# AlphaOS MinIO credentials (rename to .env, do NOT commit)
#
# Loader order (alphaos/minio.py):
#   1. ALPHAOS_ENV_FILE  (env var pointing at an absolute .env path)
#   2. ./.env  (current working dir at process start)
#   3. alphaos/.env  (alongside the installed package)
#
# Without these, AlphaOS falls back to yfinance for data (60-day cap on 5min).

MINIO_URL=http://your-minio-host:9000
MINIO_USERNAME=your-access-key
MINIO_PASSWORD=your-secret-key
MINIO_BUCKET=stocks-us

# Optional toggles
# ALPHAOS_USE_MINIO=1     # force MinIO loader path in data.py
# ALPHAOS_PARQUET_DIR=/path/to/dropin/parquets   # bypass MinIO with local parquets
