# AlphaOS — V2-FRONTIER database config (rename to .env, do NOT commit)
#
# The app stores all state (sleeves, holdings, portfolio config, NAV ledger)
# in PostgreSQL. It does NOT use MinIO/S3 or any market-data source.
#
# In Kubernetes these values come from the Crunchy (CPNG) secret
# `<cluster>-pguser-<user>` — see DEPLOYMENT.md. Locally, set them here.
#
# Loader order: ALPHAOS_DATABASE_URL takes precedence over DATABASE_URL;
# if neither is set the discrete PG* parts are used.

# Either: full connection URL (a raw Crunchy `uri` works as-is; the driver
# is normalized to psycopg3 automatically).
DATABASE_URL=postgresql://user:pass@your-postgres-host:5432/alphaos

# Or: the discrete parts (used when DATABASE_URL is unset).
# PGHOST=your-postgres-host
# PGPORT=5432
# PGUSER=alphaos
# PGPASSWORD=your-password
# PGDATABASE=alphaos
